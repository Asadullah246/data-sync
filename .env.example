# ══════════════════════════════════════════════════════════
# BioTime Data Bridge — Environment Configuration
# ══════════════════════════════════════════════════════════

# ─── PostgreSQL Connection (BioTime Database) ───────────
DB_HOST=127.0.0.1
DB_PORT=7496
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=biotime
TABLE_NAME=iclock_transaction

# ─── BioTime REST API ───────────────────────────────────
BIOTIME_BASE_URL=http://127.0.0.1:1020
BIOTIME_USERNAME=your_biotime_username
BIOTIME_PASSWORD=your_biotime_password
BIOTIME_PAGE_SIZE=200

# ─── Polling Schedule ───────────────────────────────────
# How often (in minutes) both pollers run. Default: 30
# Can be any value — overnight gaps are handled automatically.
POLL_INTERVAL_MINUTES=30

# ─── Webhook Configuration (Main Server) ────────────────
WEBHOOK_API_KEY=your_webhook_api_key

# Endpoint to receive raw attendance punch logs
ATTENDANCE_WEBHOOK_URL=https://your-server.com/api/v1/hr/attendance-transactions/webhook

# Endpoint to receive daily timecard report data
TIMECARD_WEBHOOK_URL=https://your-server.com/api/v1/hr/timecard-reports/webhook

# ─── Local Data Storage ─────────────────────────────────
# Set to "true" to save copies of data locally (useful for dev/debug).
# Set to "false" for production (no local files written).
SAVE_LOCAL=false
OUTPUT_DIR=./data
